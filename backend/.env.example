# ── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000

# ── Frontend (CORS) ──────────────────────────────────────────────────────────
# Coma-separado si tenés varios orígenes
FRONTEND_URL=http://localhost:5173

# ── Supabase ─────────────────────────────────────────────────────────────────
# Obtener desde: Supabase Dashboard > Settings > API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-publishable-key

# Service Role Key — SECRETO, solo backend, bypassa RLS (necesario para storage)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generar uno seguro, ej: openssl rand -base64 48
JWT_SECRET=cambiame-en-produccion-por-algo-largo-y-aleatorio

# ── (Opcional) Firebase ──────────────────────────────────────────────────────
# Solo si querés usar Firebase Storage en lugar de Supabase
# FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_CLIENT_EMAIL=
